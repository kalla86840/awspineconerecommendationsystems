# Local development environment variables.
# Copy values into your shell or local secret manager. Do not commit real keys.

AWS_REGION=us-west-1
AWS_DEFAULT_REGION=us-west-1
AWS_SDK_LOAD_CONFIG=1

# OpenAI API key from OpenAI. In AWS CI/CD, store this value in Secrets Manager
# and pass that secret ARN as OpenAIApiKeySecretArn.
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Pinecone API key from Pinecone. In AWS CI/CD, store this value in Secrets Manager
# and pass that secret ARN as PineconeApiKeySecretArn.
PINECONE_API_KEY=pcsk-your-pinecone-api-key
PINECONE_INDEX_NAME=news-demo
PINECONE_INDEX_HOST=https://news-demo-4fe9eo0.svc.aped-4627-b74a.pinecone.io
PINECONE_NAMESPACE=news
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=1024
PINECONE_UPSERT_ON_QUERY=false

DEPLOY_ENVIRONMENT=staging
CONFIG_PATH=config/default.yaml
RAG_KNOWLEDGE_BASE_PATH=data/rag/car_sales_knowledge.txt

